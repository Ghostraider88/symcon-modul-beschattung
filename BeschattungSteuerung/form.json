{
    "elements": [
        {
            "type": "Label",
            "caption": "Central values (time window, thresholds, lock time, global automation) are maintained as status variables and can be changed at runtime via the visualisation. Other systems can read and write them there."
        },
        {
            "type": "ExpansionPanel",
            "caption": "Cloud detection",
            "items": [
                {
                    "type": "SelectVariable",
                    "name": "CloudBrightnessID",
                    "caption": "Central brightness sensor (lux)"
                },
                {
                    "type": "ValidationTextBox",
                    "name": "SensorUnitLabel",
                    "caption": "Sensor unit (display only, e.g. lx or W/m²)"
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudSunnyThreshold",
                    "caption": "Sunny threshold (sensor unit, also used as the 'on' value for the facade fallback below)",
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "FallbackBrightnessOff",
                    "caption": "Facade fallback: 'off' value (facades without their own brightness sensor use this sensor's value with this on/off pair)",
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudChangeTolerance",
                    "caption": "Change tolerance (sensor unit)",
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudWindowMinutes",
                    "caption": "Observation window (minutes)",
                    "suffix": "min",
                    "minimum": 1
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudChangeLimitOn",
                    "caption": "Activate after N changes",
                    "minimum": 1
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudChangeLimitOff",
                    "caption": "Deactivate below N changes",
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "CloudInterval",
                    "caption": "Calculation interval (seconds)",
                    "suffix": "s",
                    "minimum": 0
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "End of day / sunset",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "UseSunsetAsLatest",
                    "caption": "Use sunset as end of day (instead of fixed 'latest' time)"
                },
                {
                    "type": "SelectVariable",
                    "name": "SunsetID",
                    "caption": "Sunset variable (location module)"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "House shape (top view, for the facade compass graphic)",
            "items": [
                {
                    "type": "Label",
                    "caption": "Rough building proportions and roof shape, shared by all facades, so the compass graphic shows which roof side you're looking at."
                },
                {
                    "type": "NumberSpinner",
                    "name": "HouseLength",
                    "caption": "Length (along ridge direction)",
                    "suffix": "m",
                    "digits": 1,
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "HouseWidth",
                    "caption": "Width (perpendicular to length)",
                    "suffix": "m",
                    "digits": 1,
                    "minimum": 0
                },
                {
                    "type": "NumberSpinner",
                    "name": "HouseRotation",
                    "caption": "Ridge/length-axis direction (compass, 0=N, 90=E)",
                    "suffix": "°",
                    "minimum": 0,
                    "maximum": 360
                },
                {
                    "type": "Select",
                    "name": "RoofShape",
                    "caption": "Roof shape",
                    "options": [
                        {
                            "caption": "Gable (Sattel)",
                            "value": 0
                        },
                        {
                            "caption": "Hip (Walm)",
                            "value": 1
                        },
                        {
                            "caption": "Shed / mono-pitch (Pult)",
                            "value": 2
                        }
                    ]
                },
                {
                    "type": "CheckBox",
                    "name": "RoofHighSideFlip",
                    "caption": "Shed roof only: high side on the other long edge (flip)"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Reliability",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "SensorMaxAge",
                    "caption": "Maximum sensor age before considered stale (seconds, 0 = off)",
                    "suffix": "s",
                    "minimum": 0
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "Display",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "EnableHTML",
                    "caption": "Create HTML status display variable"
                },
                {
                    "type": "CheckBox",
                    "name": "EnableProtocol",
                    "caption": "Create protocol variable"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Recalculate cloud detection now",
            "onClick": "BSTRG_ComputeCloudDetection($id);"
        },
        {
            "type": "Button",
            "caption": "Reset central values to defaults",
            "onClick": "BSTRG_ResetDefaults($id);"
        }
    ],
    "status": [
        {
            "code": 102,
            "icon": "active",
            "caption": "Active"
        },
        {
            "code": 104,
            "icon": "inactive",
            "caption": "Inactive"
        }
    ]
}
